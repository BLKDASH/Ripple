<?xml version="1.0" encoding="UTF-8"?>
<Installer>
    <!-- 安装包名称（显示在标题栏） -->
    <Name>凌波</Name>

    <!-- 安装包版本号，与 CMakeLists.txt 中的 project() 版本保持一致 -->
    <Version>0.1.0</Version>

    <!-- 安装程序窗口标题 -->
    <Title>凌波</Title>

    <!-- 发布者信息 -->
    <Publisher>Ripple</Publisher>
    <ProductUrl>https://github.com/BLKDASH</ProductUrl>

    <!-- 默认安装目录 -->
    <TargetDir>C:/Program Files/Ripple</TargetDir>

    <!-- 开始菜单文件夹 -->
    <StartMenuDir>Ripple</StartMenuDir>

    <!-- 安装/卸载程序图标（.ico，放在 config 目录下） -->
    <InstallerApplicationIcon>installer-icon</InstallerApplicationIcon>
    <InstallerWindowIcon>installer-icon.png</InstallerWindowIcon>

    <!-- 维护工具名称 -->
    <MaintenanceToolName>RippleMaintenanceTool</MaintenanceToolName>

    <!-- 卸载时是否删除整个目标目录 -->
    <RemoveTargetDir>true</RemoveTargetDir>

    <!-- 是否允许路径包含非 ASCII 字符（中文用户名等） -->
    <AllowNonAsciiCharacters>true</AllowNonAsciiCharacters>

    <!-- 是否允许路径包含空格 -->
    <AllowSpaceInPath>true</AllowSpaceInPath>

    <!-- 离线安装包：不显示仓库配置页，也不保存默认仓库 -->
    <RepositorySettingsPageVisible>false</RepositorySettingsPageVisible>
    <SaveDefaultRepositories>false</SaveDefaultRepositories>

    <!-- 控制脚本：允许在原路径覆盖安装 -->
    <ControlScript>controlscript.qs</ControlScript>
</Installer>
